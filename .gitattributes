# Default: auto-detect text files and normalize to LF in the repo
* text=auto eol=lf

# Python
*.py text eol=lf

# Config and docs
*.md text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.json text eol=lf

# Windows scripts — keep CRLF so they work when checked out on Windows
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary
*.exe binary
*.dll binary
